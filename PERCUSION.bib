@article{Tompkins1998b,
  title = {Radiative-Convective Equilibrium in a Three-Dimensional Cloud-Ensemble Model},
  author = {Tompkins, Adrian M. and Craig, George C.},
  year = 1998,
  month = jul,
  journal = {Quarterly Journal of the Royal Meteorological Society},
  volume = {124},
  pages = {2073--2097},
  issn = {00359009},
  doi = {10.1002/qj.49712455013},
  abstract = {A knowledge of radiative convective interactions is key to an understanding of the tropical climate. In an attempt to address this a cloud-resolving model has been run to a radiative-convective equilibrium state in three dimensions. The model includes a three-phase bulk microphysical scheme and a fully interactive two-stream broadband radiative-transfer scheme for both the infrared and solar radiation. The simulation is performed using a fixed sea surface temperature, and cyclic lateral boundary conditions. No `large-scale' convergence, mean wind shear or background vorticity was imposed. The total integration lasted 70 days, and a statistical equilibrium state was reached at all heights after 30 days of simulation in all model variables. It is seen that some variables, such as vertical mass flux, adjust quickly to their equilibrium values while others, such as column-integrated water amount, domain-mean temperature and convective available potential energy (CAPE) display variation on a longer 30-day time-scale. The equilibrium state had a column-integrated vapour amount of 42.3 kg m-2, a mean temperature of 258.7 K and a pseudo-adiabatic CAPE value of 1900 J kg-1. The equilibrium-state statistics are consistent with tropical observations. The convection does not remain randomly distributed but instead becomes organized, aligning in a band structure associated with high moisture values in the boundary layer. This organization seems to result from interactions between radiation, convection and surface fluxes. The surface-flux feedback is due to higher boundary-layer winds, associated with convection, increasing surface fluxes of moisture locally. Horizontally inhomogeneous radiation can act to make clouds longer lasting and also increase convergence into cloudy region. Replacing the wind-sensitive surface-flux calculation with a linear relaxation to surface values appeared to largely destroy this organization, as did the use of an imposed horizontally uniform radiative-heating rate.},
  keywords = {climate,cloud-resolving model convection tropical},
  file = {/Users/juliawindmiller/Zotero/storage/9ZT3PC6M/1998-Radiative-convective_equilibrium_in_a_three-dimensional_cloud-ensemble_model.pdf}
}

@article{Tompkins2001a,
  title = {On the Relationship between Tropical Convection and Sea Surface Temperature},
  author = {Tompkins, {\relax AM}},
  year = 2001,
  month = mar,
  journal = {Journal of climate},
  volume = {14},
  pages = {633--637},
  doi = {10.1175/1520-0442(2001)014<0633:OTRBTC>2.0.CO;2},
  urldate = {2012-12-12},
  abstract = {Tropical observations show convective activity increasing sharply above sea surface temperatures (SSTs) of around 26{$^\circ$}C and then decreasing as the SST exceeds 30{$^\circ$}C, with maximum observed SSTs of around 32{$^\circ$}C.Although some aspects of this relationship are reasonably well understood, as of yet no theory has explained the decrease in convective activity above 30{$^\circ$}C. Here it is suggested that this aspect of the relationship could result from a organizational positive feedback, sometimes termed `self aggregation,' whereby the occurrence of convection makes future convection more likely to occur in the same location. Using cloud-resolving simulations, it is shown that the feedback between convection and the water vapor field is a good candidate for this role.},
  file = {/Users/juliawindmiller/Zotero/storage/34PJ2XYH/2001-On_the_relationship_between_tropical_convection_and_sea_surface_temperature.pdf}
}

@article{Tompkins2001b,
  title = {Organization of {{Tropical Convection}} in {{Low Vertical Wind Shears}}: {{The Role}} of {{Cold Pools}}},
  author = {Tompkins, Adrian M.},
  year = 2001,
  month = mar,
  journal = {Journal of the Atmospheric Sciences},
  volume = {58},
  pages = {1650--1672},
  issn = {0022-4928},
  doi = {10.1175/1520-0469(2001)058<1650:OOTCIL>2.0.CO;2},
  abstract = {A modeling study is conducted to gain insight into the factors that\textbackslash ncontrol the intensity and organization of tropical convection, and\textbackslash nin particular to examine if organization occurs in the absence of\textbackslash nfactors such as vertical wind shear or underlying sea surface temperature\textbackslash n(SST) gradient. The control experiment integrates a cloud-resolving\textbackslash nmodel for 15 days using a 3D domain exceeding 1000 km in length,\textbackslash nwith no imposed winds, and horizontally uniform SST and forcing for\textbackslash nconvection. After 2 days of random activity, the convection organizes\textbackslash ninto clusters with dimensions of approximately 200 km. Convective\textbackslash nsystems propagate through the clusters at speeds of 2--3 m s-1, while\textbackslash nthe clusters themselves propagate at minimal speeds of around 0.5\textbackslash nm s-1.\textbackslash n\textbackslash n\textbackslash nExamining the thermodynamic structure of the model domain, it is found\textbackslash nthat the convective free bands separating the clusters are very dry\textbackslash nthroughout the troposphere, and due to virtual temperature effects,\textbackslash nare correspondingly warmer in the lower troposphere and boundary\textbackslash nlayer. This suggests a positive feedback between convection and water\textbackslash nvapor, where convective moistening of the local atmosphere renders\textbackslash nit more favorable to future convection. The existence of this feedback\textbackslash nis demonstrated by experiments in which the free-tropospheric water\textbackslash nvapor is perturbed in convective regions, and it is found that the\textbackslash nlower-atmospheric water vapor is most critical in controlling convection,\textbackslash nmost likely through the role of downdrafts. Examination of the boundary\textbackslash nlayer in the control experiment also indicated that convectively\textbackslash ngenerated cold pools also play a key role in the organization of\textbackslash nconvection, possibly by their influence on the boundary layer water\textbackslash nvapor field.\textbackslash n\textbackslash n\textbackslash nIn order to see how the water vapor feedback modifies established\textbackslash nconvective organization, a further experiment was conducted with\textbackslash nan SST gradient imposed, which established a mock Walker cell type\textbackslash ncirculation, with ascending motion over the warmest SSTs. After 5\textbackslash ndays, the SST gradient is reversed to see how the convection would\textbackslash nestablish itself over the new SST maximum. This highly idealized\textbackslash nexperiment therefore represents a surrogate for the atmospheric response\textbackslash nto SST ``hotspots,'' that observations have shown to form under the\textbackslash ndescending branch of large-scale tropical circulations such as the\textbackslash nMadden--Jullian oscillation, due to increased incident solar radiation\textbackslash nand decreased latent heat fluxes at the surface. It is found that\textbackslash nthe convection does not spontaneously initiate over the new SST maximum,\textbackslash nbut instead must propagate toward it. After a further 5 days, much\textbackslash nlonger than the boundary layer adjustment timescale, the warmest\textbackslash nSSTs are still completely free from convection. This is directly\textbackslash ndue to the dryness of the atmosphere caused by the initial period\textbackslash nof subsidence.\textbackslash n\textbackslash n\textbackslash nA further set of experiments examines the robustness of the feedback\textbackslash nin cases of imposed vertical wind shear. It is found that strong\textbackslash nwind shears prevent the feedback by effectively mixing water vapor.\textbackslash nHowever, the feedback is still very important in cases of weak wind\textbackslash nshears.},
  file = {/Users/juliawindmiller/Zotero/storage/BLK2TSLU/2001-Organization_of_Tropical_Convection_in_Low_Vertical_Wind_Shears_The_Role_of_Cold_Pools.pdf}
}

