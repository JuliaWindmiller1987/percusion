@article{
  title = {Relocation of {{GATE}} from the {{Pacific}} to the {{Atlantic}}},
  author = {Zhang, Chidong and Wallace, John M. and Houze, Robert A. and Zipser, Edward J. and Emanuel, Kerry A.},
  year = 2022,
  month = aug,
  journal = {Bulletin of the American Meteorological Society},
  volume = {103},
  number = {8},
  pages = {E1991--E1999},
  issn = {0003-0007, 1520-0477},
  doi = {10.1175/BAMS-D-21-0151.1},
  urldate = {2023-04-07},
  abstract = {Abstract This article documents historically the planning of the Global Atmospheric Research Program's (GARP) Atlantic Tropical Experiment (GATE), the largest atmospheric field program of all time. In its earliest planning, GATE was called the Tropical Meteorological Experiment (TROMEX) and was designed to be in the tropical western Pacific. For reasons including concerns of the U.S. Department of Defense, the international project was relocated to the tropical Atlantic and renamed GATE.}
}

