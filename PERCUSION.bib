  file = {/Users/juliawindmiller/Zotero/storage/CUI6XCRZ/2006-Critical_phenomena_in_atmospheric_precipitation.pdf;/Users/juliawindmiller/Zotero/storage/WBTGK2CP/Peters, Neelin - 2006 - Critical phenomena in atmospheric precipitation - Notes.pdf}
