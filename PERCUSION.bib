@article{
  title = {Global {{Cloud-Resolving Models}}},
  author = {Satoh, Masaki and Stevens, Bjorn and Judt, Falko and Khairoutdinov, Marat and Lin, Shian-Jiann and Putman, William M. and D{\"u}ben, Peter},
