@article{umaAssessmentVerticalAir2021,
  title = {Assessment of Vertical Air Motion among Reanalyses and Qualitative Comparison with Very-High-Frequency Radar Measurements over Two Tropical Stations},
  author = {Uma, Kizhathur Narasimhan and Das, Siddarth Shankar and Ratnam, Madineni Venkat and Suneeth, Kuniyil Viswanathan},
  year = 2021,
  month = feb,
  journal = {Atmospheric Chemistry and Physics},
  volume = {21},
  number = {3},
  pages = {2083--2103},
