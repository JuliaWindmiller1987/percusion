@inproceedings{Emanuel2004,
  title = {Tropical Cyclone Activity and the Global Climate System},
  booktitle = {26th {{AMS Conference}} on {{Hurricans}} and {{Tropical Meteorology}}},
  author = {Emanuel, Kerry and Nolan, David S.},
  year = 2004,
  publisher = {American Meteorological Society},
  address = {Miami},
  issn = {21698996},
  doi = {10.1029/2001JD001002},
  abstract = {Among the most intriguing enigmas of the climate system is that on\textbackslash nthe one hand, the Earth's climate appears to be exquisitely sensitive\textbackslash nto relatively minor variations in the distribution of insolation\textbackslash nowing to orbital variations, but on the other hand, it is in a grosser\textbackslash nsense stable, in that it has varied only moderately in response to\textbackslash na roughly 30\% increase in solar insolation over the life of the planet.\textbackslash nTo this enigma may be added the evidence that climate may undergo\textbackslash nextraordinarily abrupt transitions. An attractive idea to help explain\textbackslash nthese characteristics is the notion that the Earth possesses a limited\textbackslash nnumber of stable climate regimes that may overlap to produce multiple\textbackslash nequilibrium states for the same solar forcing. Here we present a\textbackslash nsimple model that produces such overlapping stable equilibria, based\textbackslash non a few key feedback processes. These include control of atmospheric\textbackslash nclouds and water vapor by the large-scale circulation of the atmosphere,\textbackslash ncontrol of the depth and intensity of the ocean's thermohaline circulation\textbackslash nby tropical cyclones, and the dependence of atmospheric CO2 content\textbackslash non ocean temperature and the strength of the thermohaline circulation.\textbackslash nWe will show that these key feedback processes produce a climate\textbackslash nwith two or three stable, overlapping climate regimes. Subjecting\textbackslash nthis system to variations in climate forcing can account for several\textbackslash nobserved features of the climate system, including abrupt transitions,\textbackslash nsensitivity to orbital variations, arctic warmth and high bottom\textbackslash nwater temperature during the Eocene and late Cretaceous, tempestites,\textbackslash nand possible episodes of deep ocean anoxia during the Cretaceous.},
  isbn = {01480227 (ISSN)},
  keywords = {Climate regimes,Eocene warmth,Hurricanes,Paleoclimate,Thermohaline},
  file = {/Users/juliawindmiller/Zotero/storage/IL6QNLM7/2004-Tropical_cyclone_activity_and_the_global_climate_system.pdf}
}

@article{Emanuel2014,
  title = {Radiative-Convective Instability},
  author = {Emanuel, Kerry and Wing, Allison A. and Vincent, Emmanuel M.},
  year = 2014,
  month = jan,
  journal = {Journal of Advances in Modeling Earth Systems},
  volume = {6},
  pages = {75--90},
  issn = {19422466},
  doi = {10.1002/2013MS000270},
  urldate = {2014-02-07},
  abstract = {Large-eddy simulation is used to study the sensitivity of trade wind cumulus clouds to pertur-bations in cloud droplet number concentrations. We find that the trade wind cumulus system approaches a radiative-convective equilibrium state, modified by net warming and drying from imposed large-scale advective forcing. The system requires several days to reach equilibrium when cooling rates are specified but much less time, and with less sensitivity to cloud droplet number density, when radiation depends real-istically on the vertical distribution of water vapor. The transient behavior and the properties of the near-equilibrium cloud field depend on the microphysical state and therefore on the cloud droplet number den-sity, here taken as a proxy for the ambient aerosol. The primary response of the cloud field to changes in the cloud droplet number density is deepening of the cloud layer. This deepening leads to a decrease in rel-ative humidity and a faster evaporation of small clouds and cloud remnants constituting a negative lifetime effect. In the near-equilibrium regime, the decrease in cloud cover compensates much of the Twomey effect, i.e., the brightening of the clouds, and the overall aerosol effect on the albedo of the organized pre-cipitating cumulus cloud field is small.},
  isbn = {0140917101},
  keywords = {convection,radiation,self-aggregation},
  file = {/Users/juliawindmiller/Zotero/storage/GNHVW4W3/2014-Radiative-convective_instability.pdf}
}

