@article{Marion2019,
  title = {The {{Dynamical Coupling}} of {{Convective Updrafts}}, {{Downdrafts}}, and {{Cold Pools}} in {{Simulated Supercell Thunderstorms}}},
  author = {Marion, G. R. and Trapp, R. J.},
  year = 2019,
  journal = {Journal of Geophysical Research: Atmospheres},
  volume = {124},
